{
  "name": "idolbooth-server",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=20.10"
  },
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc --noEmit",
    "lint": "eslint .",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "test": "vitest run",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "d1:migrate": "npx wrangler d1 migrations apply batchloom-db --remote",
    "d1:migrate:local": "npx wrangler d1 migrations apply batchloom-db --local",
    "seed": "tsx src/db/seed/seed.ts",
    "generate-assets": "tsx scripts/generate-assets.ts"
  },
  "dependencies": {
    "@lucia-auth/adapter-sqlite": "3.0.1",
    "better-sqlite3": "11.3.0",
    "drizzle-orm": "0.34.0",
    "hono": "4.6.3",
    "lucia": "3.2.0",
    "openai": "4.67.3",
    "sharp": "0.33.5",
    "stripe": "17.0.0",
    "zod": "3.23.8"
  },
  "devDependencies": {
    "@eslint/js": "9.9.0",
    "@types/better-sqlite3": "7.6.11",
    "@types/node": "22.5.5",
    "drizzle-kit": "0.25.0",
    "eslint": "9.9.0",
    "globals": "15.9.0",
    "prettier": "3.3.3",
    "tsx": "4.19.1",
    "typescript": "5.5.3",
    "typescript-eslint": "8.0.1",
    "vitest": "2.1.2"
  }
}
